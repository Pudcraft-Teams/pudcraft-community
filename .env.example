# ============================================
# Pudcraft Community — 环境变量配置
# 复制此文件为 .env 后填入真实值
# cp .env.example .env
# ============================================

# === 数据库（PostgreSQL） ===
DATABASE_URL="postgresql://pudcraft:pudcraft_dev@localhost:5432/pudcraft?schema=public"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === 应用配置 ===
NODE_ENV="development"
LOG_LEVEL="info"
NEXTAUTH_SECRET="replace_with_openssl_rand_base64_32"

# === SMTP（飞书企业邮箱） ===
SMTP_HOST="smtp.feishu.cn"
SMTP_PORT="465"
SMTP_USER="secure@pudcraft.cn"
SMTP_PASS="your_smtp_password_or_app_token"
SMTP_FROM="PudCraft <secure@pudcraft.cn>"

# === 未来扩展（当前无需配置） ===
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# AUTH_SECRET="生成一个安全的随机字符串"
# RATE_LIMIT_MAX="60"
